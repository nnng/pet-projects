{
  "name": "screen-translator",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "desktop-app",
    "backend"
  ],
  "scripts": {
    "dev:desktop": "npm run dev -w desktop-app",
    "dev:backend": "npm run dev -w backend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:desktop\""
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
